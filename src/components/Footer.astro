---
import { config } from '../data/config';
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="grid">
      <div>
        <div class="brand">
          <span class="icon">{config.iconLetter}</span>
          <strong>{config.name}</strong>
        </div>
        <p>{config.tagline}</p>
      </div>
      <div>
        <h4>Producto</h4>
        <ul>
          <li><a href="/#features">Features</a></li>
          <li><a href="/#download">Descargar</a></li>
        </ul>
      </div>
      <div>
        <h4>Legal</h4>
        <ul>
          <li><a href="/privacy">Privacidad</a></li>
          <li><a href="/terms">Términos</a></li>
        </ul>
      </div>
      <div>
        <h4>Contacto</h4>
        <ul>
          <li><a href={`mailto:${config.contactEmail}`}>{config.contactEmail}</a></li>
          <li><a href={config.publisherUrl} target="_blank" rel="noopener">{config.publisher}</a></li>
        </ul>
      </div>
    </div>
    <div class="bottom">
      <span>© {year} {config.publisher}. Todos los derechos reservados.</span>
      <span>Hecho en LATAM</span>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid #0f172a;
    padding: 4rem 0 2rem;
    background: #02040a;
  }
  .grid {
    display: grid;
    grid-template-columns: 2fr repeat(3, 1fr);
    gap: 2.5rem;
    margin-bottom: 3rem;
  }
  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr 1fr; }
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .icon {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 800;
  }
  footer p {
    color: #64748b;
    font-size: 0.9rem;
  }
  h4 {
    color: #fff;
    font-size: 0.95rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }
  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  ul a {
    color: #64748b;
    font-size: 0.9rem;
  }
  ul a:hover { color: #fff; text-decoration: none; }
  .bottom {
    padding-top: 2rem;
    border-top: 1px solid #0f172a;
    display: flex;
    justify-content: space-between;
    color: #475569;
    font-size: 0.85rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
</style>

---
import { config } from '../data/config';
---

<section id="features" class="features">
  <div class="container">
    <h2>Qué hace</h2>
    <p class="subtitle">{config.longDescription}</p>
    <div class="grid">
      {config.features.map(f => (
        <div class="card">
          <div class="icon">{f.icon}</div>
          <h3>{f.title}</h3>
          <p>{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: 5rem 0;
    border-top: 1px solid #0f172a;
    background: #060f1f;
  }
  h2 {
    font-size: 2rem;
    color: #fff;
    text-align: center;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  .subtitle {
    text-align: center;
    color: #94a3b8;
    max-width: 680px;
    margin: 0 auto 3rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .card {
    background: #0f172a;
    border: 1px solid #1e293b;
    padding: 2rem;
    border-radius: 16px;
    transition: transform 0.2s, border-color 0.2s;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
  }
  .icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  h3 {
    color: #fff;
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }
  .card p {
    color: #94a3b8;
    font-size: 0.95rem;
  }
</style>

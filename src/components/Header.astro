---
import { config } from '../data/config';
---

<header>
  <nav class="container">
    <a href="/" class="brand">
      <span class="icon">{config.iconLetter}</span>
      <span>{config.name}</span>
    </a>
    <ul>
      <li><a href="/#features">Features</a></li>
      <li><a href="/#download">Descargar</a></li>
      <li><a href="/privacy">Privacidad</a></li>
    </ul>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(3, 7, 18, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #1e293b;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
  }
  .brand:hover { text-decoration: none; }
  .icon {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 800;
  }
  ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }
  ul a {
    color: #94a3b8;
    font-size: 0.9rem;
    font-weight: 500;
  }
  ul a:hover { color: #fff; text-decoration: none; }
  @media (max-width: 600px) {
    ul { gap: 1rem; }
    ul a { font-size: 0.8rem; }
  }
</style>
